# =========================================================
# GreenGate Environment Template
# Copy relevant values into service-specific files:
# - backend/.env
# - frontend/.env
# - blockchain/.env
# =========================================================

# --------------------
# Shared / Blockchain
# --------------------
# Polygon Amoy RPC endpoint
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# Deployer wallet private key for Hardhat deploys (blockchain/.env)
# Example format: 0xabc123...
DEPLOYER_PRIVATE_KEY=0x_your_wallet_private_key

# Deployed CarbonReportRegistry contract address
# Filled after deployment and used by backend + frontend
CONTRACT_ADDRESS=0x_fill_after_deploy

# --------------------
# Backend (backend/.env)
# --------------------
# REQUIRED: used to sign and verify JWTs
JWT_SECRET_KEY=replace_with_a_long_random_secret

# development | production
ENVIRONMENT=development

# REQUIRED in production: comma-separated allowed origins
# Example: https://app.greengate.com,https://admin.greengate.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000

# SQLAlchemy database URL
DATABASE_URL=sqlite:///./greengate.db

# AI recommendations (Cerebras primary)
CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# AI fallback (Ollama local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=60

# Backend signer private key for blockchain submissions (must be contract owner wallet)
SIGNER_PRIVATE_KEY=0x_your_backend_wallet_private_key

# Optional FX override used in CBAM INR conversion
EUR_TO_INR_RATE=90.0

# --------------------
# Frontend (frontend/.env)
# --------------------
# Backend API base URL
VITE_API_URL=http://localhost:8000

# Optional display/deployment helper (used by deploy script)
VITE_CONTRACT_ADDRESS=0x_fill_after_deploy
